# 実機 E2E 用の環境変数テンプレート。
#   コピーして実値を入れる:  cp e2e/.env.example e2e/.env.local
#   .env.local は run-e2e-real-device.sh が自動で読み込む（コミット禁止）。

# ── 必須 ──
# 実機の UDID（`xcrun devicectl list devices` で確認）
IOS_DEVICE_UDID=00008110-XXXXXXXXXXXXXXXX
# 本体アプリの Bundle ID
IOS_BUNDLE_ID=com.yourname.SubBuddySpike
# 署名に使う Apple Developer Team ID（10 桁）
APPLE_TEAM_ID=ABCDE12345

# ── 任意 ──
# App Group ID（既定 group.$IOS_BUNDLE_ID）。Constants.swift の appGroupID と一致必須
# IOS_APP_GROUP=group.com.yourname.SubBuddySpike
# Web 管理画面 URL（Mac の LAN IP。既定 http://127.0.0.1:3000）
WEB_BASE_URL=http://127.0.0.1:3000
# Web 確認の対象サブスク ID（アプリの送信先 DB に実在する ID）
IOS_TEST_SUBSCRIPTION_ID=
# OS シート（Screen Time 許可・アプリ選択）を自動操作しない（既定 true）
SKIP_SYSTEM_UI=true
