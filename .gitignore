# OS / editor
.DS_Store
*.swp
.idea/
*.log

# Secrets / environment
.env
.env.*
!.env.example
*.pem
*.key
credentials*.json

# Google / OAuth credentials (WBS sync) — 絶対にコミットしない
# ※ .gitignore は行末コメント不可。コメントは必ず独立行に書く
# Google がダウンロードさせる OAuth クライアント鍵の既定名
client_secret*.json
# サービスアカウント鍵
*service-account*.json
*-sa.json
gcp-*.json
# 取得済みトークン
token.json
tokens/
# Workspace CLI のローカル認証情報置き場（想定）
.gws/
# 鍵をリポジトリ内に置く場合の隔離先（中身は追跡しない／フォルダだけ残す）
secrets/*
!secrets/.gitkeep

# Dependencies / build
node_modules/
.next/
dist/
build/
coverage/
*.tsbuildinfo

# Local/manual operation notes
manuals/

# Real data / PII (実データはリポジトリに含めない — CLAUDE.md PII方針)
data/
*.db
*.sqlite
*.sqlite3
*.dump
*.sql.gz
seed.local.*
fixtures.local.*

# iOS / Xcode (将来)
ios/**/build/
ios/**/DerivedData/
*.xcuserstate

# Claude local settings
.claude/settings.local.json

# WBS 同期のローカル状態（フック重複提案の抑止用）
wbs/.sync-state.json

# iOS Spike: 実 IP・トークンを書き込むため追跡しない（.example をコピーして使う）
spikes/ios-screen-time/SubBuddySpike/Shared/Constants.swift
