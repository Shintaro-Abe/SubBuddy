#!/usr/bin/env bash
set -euo pipefail

PROFILE="${SAKANA_CODEX_PROFILE:-sakana}"
CODEX_SAKANA_CONFIG=(--profile "$PROFILE" --disable image_generation)

if [[ -n "${SAKANA_MODEL:-}" ]]; then
  CODEX_SAKANA_CONFIG+=(--model "$SAKANA_MODEL")
fi

if [[ -n "${SAKANA_REASONING_EFFORT:-}" ]]; then
  CODEX_SAKANA_CONFIG+=(--config "model_reasoning_effort=\"$SAKANA_REASONING_EFFORT\"")
fi

run_codex() {
  codex "${CODEX_SAKANA_CONFIG[@]}" "$@"
}

if [[ -z "${SAKANA_API_KEY:-}" ]]; then
  echo "SAKANA_API_KEY is not set." >&2
  echo "Set it in your shell before running Codex with Sakana Fugu." >&2
  exit 1
fi

run_codex "$@"
