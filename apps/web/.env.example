# local | cloud-testflight | production
SUBBUDDY_MODE=local

# Local development PostgreSQL. Do not put production credentials here.
DATABASE_URL="postgresql://subbuddy:subbuddy@localhost:5432/subbuddy_dev?schema=public"

# local mode only. Use a different value in your private .env and never commit it.
USAGE_SYNC_TOKEN="replace-with-local-development-token"

# Sign in with Apple values are required for cloud-testflight / production.
# Keep real values in .env or the PaaS secret store, not in this file.
APPLE_TEAM_ID=""
# Comma-separated aud allowlist for Sign in with Apple identity tokens.
# Web Services ID + iOS app Bundle ID (ADR 0004).
APPLE_ALLOWED_CLIENT_IDS="com.subbuddy.web,com.subbuddy.app"
# Web Services ID. It must also be present in APPLE_ALLOWED_CLIENT_IDS.
APPLE_CLIENT_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
# HTTPS return URL registered in Apple Developer.
APPLE_REDIRECT_URI=""

# Optional. Set in cloud-testflight / production to make stored Apple subject hashes environment-specific.
APPLE_SUBJECT_HASH_SALT=""

# Required in cloud-testflight / production. Generate a different 256-bit value per environment.
AUTH_JWT_SECRET_BASE64URL=""
AUTH_TOKEN_ISSUER=""
AUTH_TOKEN_AUDIENCE=""

# Approved session limits. Keep them explicit in each cloud environment.
AUTH_ACCESS_TTL_SECONDS="900"
AUTH_WEB_SESSION_TTL_SECONDS="86400"
AUTH_IDLE_TTL_SECONDS="2592000"
AUTH_ABSOLUTE_TTL_SECONDS="7776000"
AUTH_APPLE_OUTAGE_GRACE_SECONDS="259200"
# Set only while an Apple sign-in outage is active; unset after recovery.
# AUTH_APPLE_OUTAGE_STARTED_AT="2026-01-01T00:00:00.000Z"

# Use __Host-subbuddy-testflight-* in cloud-testflight and __Host-subbuddy-* in production.
AUTH_ACCESS_COOKIE_NAME=""
AUTH_REFRESH_COOKIE_NAME=""
AUTH_CSRF_COOKIE_NAME=""
AUTH_ALLOWED_ORIGINS=""
