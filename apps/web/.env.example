# local | cloud-testflight | production
SUBBUDDY_MODE=local

# Local development PostgreSQL. Do not put production credentials here.
DATABASE_URL="postgresql://subbuddy:subbuddy@localhost:5432/subbuddy_dev?schema=public"

# local mode only. Use a different value in your private .env and never commit it.
USAGE_SYNC_TOKEN="replace-with-local-development-token"

# Sign in with Apple values are required for cloud-testflight / production.
# Keep real values in .env or the PaaS secret store, not in this file.
APPLE_TEAM_ID=""
APPLE_CLIENT_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_REDIRECT_URI=""

# Optional. Set in cloud-testflight / production to make stored Apple subject hashes environment-specific.
APPLE_SUBJECT_HASH_SALT=""
